# Flask Configuration
SECRET_KEY=ghar-ka-khana-secret-key-2024
JWT_SECRET_KEY=jwt-secret-string-ghar-ka-khana
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///gharkaakhana.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost/gharkaakhana

# Redis (for rate limiting and caching)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (for order confirmations)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=orders@gharkaakhana.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Google Maps API (for location services)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Client Configuration
CLIENT_URL=http://localhost:3000

# Production Settings
# FLASK_ENV=production
# DATABASE_URL=postgresql://user:pass@localhost/production_db
# REDIS_URL=redis://redis-server:6379/0